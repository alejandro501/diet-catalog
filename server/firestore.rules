rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function canReadSharedDiet(resourceData) {
      return request.auth != null
        && (
          resourceData.ownerId == request.auth.uid
          || resourceData.isGlobal == true
          || request.auth.uid in resourceData.recipientIds
        );
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /catalogItems/{itemId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /profiles/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /sharedDiets/{shareId} {
      allow read: if canReadSharedDiet(resource.data);
      allow create, update: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;

      match /items/{itemId} {
        allow read: if canReadSharedDiet(get(/databases/$(database)/documents/sharedDiets/$(shareId)).data);
        allow write: if request.auth != null
          && get(/databases/$(database)/documents/sharedDiets/$(shareId)).data.ownerId == request.auth.uid;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
